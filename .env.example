# PostHog (optional)
# If NEXT_PUBLIC_POSTHOG_KEY is missing, analytics is disabled.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Convex HTTP API base (read endpoints)
# Example: https://<your-deployment>.convex.site
NEXT_PUBLIC_CONVEX_API_BASE=

# Convex ingest endpoint + bearer token (used by CI/scripts)
# Example endpoint: https://<your-deployment>.convex.site/ingestOfferProbe
CONVEX_INGEST_URL=
VACANCY_INGEST_TOKEN=
CONVEX_ADMIN_TOKEN=
