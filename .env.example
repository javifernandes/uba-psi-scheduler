# PostHog (optional)
# If NEXT_PUBLIC_POSTHOG_KEY is missing, analytics is disabled.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Clerk (optional in local keyless mode, recommended in deployed environments)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex HTTP API base (read endpoints)
# Example: https://<your-deployment>.convex.site
NEXT_PUBLIC_CONVEX_API_BASE=

# Convex client URL (used by convex/react in browser)
# Example: https://<your-deployment>.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Convex auth provider trust for Clerk-issued tokens
# Example: https://<your-instance>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Convex ingest endpoint + bearer token (used by CI/scripts)
# Example endpoint: https://<your-deployment>.convex.site/ingestOfferProbe
CONVEX_INGEST_URL=
VACANCY_INGEST_TOKEN=
CONVEX_ADMIN_TOKEN=
