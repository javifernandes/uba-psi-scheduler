{
  "name": "uba-psi-scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview:static": "cd out && python3 -m http.server 4173",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "inspect:catalog": "tsx scripts/inspect-uba-psi-catalog.ts",
    "scrape:catalog": "tsx scripts/scrape-uba-psi-oferta.ts",
    "probe:push-convex": "tsx scripts/push-offer-probe-to-convex.ts",
    "convex:admin": "tsx scripts/convex-admin.ts",
    "backfill:vacancies": "tsx scripts/backfill-vacancies-from-git.ts",
    "migrate:subject-schema-v2": "tsx scripts/migrate-subject-schema-v2.ts",
    "scrape:window:status": "tsx scripts/scraper-window-control.ts status",
    "scrape:window:close": "tsx scripts/scraper-window-control.ts close",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.575.0",
    "next": "^14.2.0",
    "posthog-js": "^1.359.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "shepherd.js": "^15.2.1",
    "tailwind-merge": "^2.3.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "convex": "^1.23.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{mjs,cjs,json,md,css}": [
      "prettier --write"
    ]
  }
}
